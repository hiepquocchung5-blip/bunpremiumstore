# scottsub/.htaccess

# 1. Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# 2. Force HTTPS (Optional - Uncomment if you have SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Protect Sensitive Directories
# FIXED: Removed 'uploads' from the forbidden list so images can be served
RewriteRule ^(includes|sql)/ - [F,L]

# 3.1 Security: Prevent PHP execution inside the uploads folder
# This ensures that even if a hacker uploads a .php file disguised as an image, it won't run.
RewriteRule ^uploads/.*\.(php|phtml|php[0-9])$ - [F,L]

# 4. Protect Sensitive Files
<FilesMatch "\.(sql|log|ini|env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# 5. Disable Directory Browsing
Options -Indexes

# 6. Clean URL Routing (Optional Enhancement)
# Turns /product/123 into index.php?module=shop&page=product&id=123
# RewriteRule ^product/([0-9]+)$ index.php?module=shop&page=product&id=$1 [L,QSA]
# RewriteRule ^category/([0-9]+)$ index.php?module=shop&page=category&id=$1 [L,QSA]
# Turns /shop/instagram-followers-premium into the public product page
RewriteRule ^shop/([A-Za-z0-9-]+)/?$ index.php?module=shop&page=product&slug=$1 [L,QSA,NC]

# 7. Error Handling
ErrorDocument 404 /index.php?module=error&page=404
ErrorDocument 403 /index.php?module=error&page=403
ErrorDocument 500 /index.php?module=error&page=500
